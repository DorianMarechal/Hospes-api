// ==========================================
// HOSPES - Modélisation des entités
// Pour dbdiagram.io
// ==========================================

// ---------- AUTHENTIFICATION ----------

Table user {
  id uuid [pk]
  email varchar(180) [unique, not null]
  password varchar(255) [not null]
  role varchar(20) [not null, note: 'ROLE_HOTE, ROLE_STAFF, ROLE_ADMIN, ROLE_CUSTOMER']
  first_name varchar(100) [not null]
  last_name varchar(100) [not null]
  phone varchar(20)
  reset_token varchar(100) [unique, note: 'Token de reinitialisation mot de passe']
  reset_token_expires_at timestamp
  is_active boolean [default: true]
  created_at timestamp [not null]
  updated_at timestamp
}

// ---------- LOGEMENT ----------

Table lodging {
  id uuid [pk]
  host_id uuid [not null, ref: > user.id]
  name varchar(150) [not null]
  type varchar(30) [not null, note: 'hotel_room, gite, cabin, bnb, apartment']
  description text
  capacity int [not null]
  base_price_week int [not null, note: 'En centimes']
  base_price_weekend int [not null, note: 'En centimes']
  cleaning_fee int [default: 0, note: 'En centimes, facture une fois par sejour']
  tourist_tax_per_person int [default: 0, note: 'En centimes, par personne par nuit']
  deposit_amount int [default: 0, note: 'En centimes, montant de la caution']
  cancellation_policy varchar(20) [not null, default: 'moderate', note: 'flexible, moderate, strict']
  min_stay int [default: 1, note: 'Fallback global, surchargeable par saison']
  max_stay int [note: 'Fallback global, surchargeable par saison']
  orphan_protection boolean [default: false]
  checkin_time time [not null, note: 'Ex: 15:00']
  checkout_time time [not null, note: 'Ex: 11:00']
  address varchar(255) [not null]
  city varchar(100) [not null]
  region varchar(100)
  postal_code varchar(10) [not null]
  country varchar(2) [not null, default: 'FR', note: 'Code ISO 3166-1 alpha-2']
  latitude decimal(10,7)
  longitude decimal(10,7)
  average_rating decimal(2,1) [note: 'Denormalise, mis a jour a chaque avis']
  review_count int [default: 0, note: 'Denormalise']
  is_active boolean [default: true]
  created_at timestamp [not null]
  updated_at timestamp
}

// ---------- PHOTOS ----------

Table lodging_image {
  id uuid [pk]
  lodging_id uuid [not null, ref: > lodging.id]
  url varchar(500) [not null]
  alt_text varchar(255)
  position int [not null, note: 'Ordre affichage, 1 = photo principale']
  created_at timestamp [not null]
}

// ---------- EQUIPEMENTS ----------

Table amenity {
  id uuid [pk]
  name varchar(80) [unique, not null, note: 'Ex: wifi, parking, piscine, climatisation']
  icon varchar(50) [note: 'Nom icone pour le front']
}

Table lodging_amenity {
  id uuid [pk]
  lodging_id uuid [not null, ref: > lodging.id]
  amenity_id uuid [not null, ref: > amenity.id]

  indexes {
    (lodging_id, amenity_id) [unique]
  }
}

// ---------- SAISON / TARIFICATION ----------

Table season {
  id uuid [pk]
  lodging_id uuid [not null, ref: > lodging.id]
  name varchar(80) [not null, note: 'Ex: Haute saison, Basse saison']
  start_date date [not null]
  end_date date [not null]
  price_week int [not null, note: 'En centimes, remplace base_price_week']
  price_weekend int [not null, note: 'En centimes, remplace base_price_weekend']
  min_stay int [note: 'Override du min_stay du lodging']
  max_stay int [note: 'Override du max_stay du lodging']
  created_at timestamp [not null]
  updated_at timestamp
}

// ---------- RESERVATION ----------

Table booking {
  id uuid [pk]
  lodging_id uuid [not null, ref: > lodging.id]
  customer_id uuid [not null, ref: > user.id]
  reference varchar(30) [unique, not null, note: 'Code non devinable']
  checkin date [not null]
  checkout date [not null]
  guests_count int [not null]
  number_of_nights int [not null, note: 'Denormalise']
  nights_total int [not null, note: 'En centimes, somme des nuits']
  cleaning_fee int [not null, note: 'En centimes, snapshot du lodging a la creation']
  tourist_tax_total int [not null, note: 'En centimes, tax_per_person * guests * nights']
  deposit_amount int [not null, note: 'En centimes, snapshot du lodging a la creation']
  total_price int [not null, note: 'En centimes, nights + cleaning + tax']
  status varchar(20) [not null, note: 'pending, confirmed, cancelled, completed']
  cancellation_policy varchar(20) [not null, note: 'Snapshot de la politique au moment de la resa']
  expires_at timestamp [note: 'TTL 15 min pour les pending']
  cancelled_by uuid [ref: > user.id, note: 'Qui a annule (hote ou customer)']
  cancellation_reason varchar(500)
  created_at timestamp [not null]
  updated_at timestamp
}

// ---------- DETAIL PRIX NUIT PAR NUIT ----------

Table booking_night {
  id uuid [pk]
  booking_id uuid [not null, ref: > booking.id]
  date date [not null, note: 'La nuit du date au date+1']
  price int [not null, note: 'En centimes']
  source varchar(80) [not null, note: 'Ex: season:Haute saison:weekend, base:week']

  indexes {
    (booking_id, date) [unique]
  }
}

// ---------- PAIEMENT ----------

Table payment {
  id uuid [pk]
  booking_id uuid [not null, ref: > booking.id]
  amount int [not null, note: 'En centimes']
  type varchar(20) [not null, note: 'booking, refund']
  method varchar(20) [not null, note: 'card, bank_transfer']
  status varchar(20) [not null, note: 'pending, succeeded, failed, refunded']
  provider varchar(20) [note: 'stripe, paypal, etc.']
  provider_transaction_id varchar(255) [note: 'Reference du provider']
  refund_reason varchar(500)
  created_at timestamp [not null]
  updated_at timestamp
}

// ---------- CAUTION ----------

Table deposit {
  id uuid [pk]
  booking_id uuid [unique, not null, ref: > booking.id, note: 'Une caution par reservation']
  amount int [not null, note: 'En centimes, montant initial retenu']
  status varchar(30) [not null, note: 'held, released, partially_retained, fully_retained']
  retained_amount int [default: 0, note: 'En centimes, montant conserve par hote']
  retained_reason varchar(500)
  released_at timestamp
  created_at timestamp [not null]
  updated_at timestamp
}

// ---------- BLOCAGE DE DATES ----------

Table blocked_date {
  id uuid [pk]
  lodging_id uuid [not null, ref: > lodging.id]
  start_date date [not null]
  end_date date [not null]
  reason varchar(255) [note: 'Entretien, usage personnel, etc.']
  source varchar(10) [not null, note: 'manual, ical']
  created_at timestamp [not null]
}

// ---------- SYNC ICAL ----------

Table ical_feed {
  id uuid [pk]
  lodging_id uuid [not null, ref: > lodging.id]
  url varchar(500) [not null]
  direction varchar(10) [not null, note: 'import, export']
  last_sync_at timestamp
  created_at timestamp [not null]
}

// ---------- STAFF ----------

Table staff_assignment {
  id uuid [pk]
  staff_id uuid [not null, ref: > user.id]
  host_id uuid [not null, ref: > user.id]
  is_revoked boolean [default: false]
  invitation_token varchar(100) [unique, note: 'Token envoye par email']
  invitation_expires_at timestamp
  invitation_accepted_at timestamp
  created_at timestamp [not null]
  updated_at timestamp
}

Table staff_permission {
  id uuid [pk]
  staff_assignment_id uuid [not null, ref: > staff_assignment.id]
  permission varchar(30) [not null, note: 'can_view_bookings, can_edit_bookings, can_block_dates, can_view_revenue, can_manage_lodgings']
}

Table staff_lodging {
  id uuid [pk]
  staff_assignment_id uuid [not null, ref: > staff_assignment.id]
  lodging_id uuid [not null, ref: > lodging.id]

  indexes {
    (staff_assignment_id, lodging_id) [unique]
  }
}

// ---------- MESSAGERIE ----------

Table conversation {
  id uuid [pk]
  lodging_id uuid [not null, ref: > lodging.id]
  customer_id uuid [not null, ref: > user.id]
  host_id uuid [not null, ref: > user.id]
  booking_id uuid [ref: > booking.id, note: 'Nullable, peut exister avant reservation']
  status varchar(20) [not null, default: 'open', note: 'open, closed, archived']
  created_at timestamp [not null]
  updated_at timestamp

  indexes {
    (lodging_id, customer_id) [unique, note: 'Une conversation par client par logement']
  }
}

Table message {
  id uuid [pk]
  conversation_id uuid [not null, ref: > conversation.id]
  sender_id uuid [not null, ref: > user.id]
  body text [not null]
  is_read boolean [default: false]
  read_at timestamp
  created_at timestamp [not null]
}

// ---------- FAVORIS ----------

Table favorite {
  id uuid [pk]
  customer_id uuid [not null, ref: > user.id]
  lodging_id uuid [not null, ref: > lodging.id]
  created_at timestamp [not null]

  indexes {
    (customer_id, lodging_id) [unique]
  }
}

// ---------- AVIS ----------

Table review {
  id uuid [pk]
  booking_id uuid [unique, not null, ref: > booking.id, note: 'Un seul avis par reservation']
  customer_id uuid [not null, ref: > user.id]
  lodging_id uuid [not null, ref: > lodging.id]
  rating int [not null, note: '1 a 5']
  comment text
  host_response text
  host_response_at timestamp
  moderated_at timestamp [note: 'Date de moderation par admin']
  moderated_by uuid [ref: > user.id, note: 'Admin qui a modere']
  created_at timestamp [not null]
}

// ---------- HISTORIQUE STATUTS RESERVATION ----------

Table booking_status_history {
  id uuid [pk]
  booking_id uuid [not null, ref: > booking.id]
  from_status varchar(20) [note: 'Null pour la creation initiale']
  to_status varchar(20) [not null]
  changed_by uuid [ref: > user.id, note: 'User qui a declenche le changement']
  reason varchar(500)
  created_at timestamp [not null]
}

// ---------- NOTIFICATIONS ----------

Table notification {
  id uuid [pk]
  user_id uuid [not null, ref: > user.id]
  type varchar(50) [not null, note: 'booking_confirmed, booking_cancelled, booking_modified, booking_expired, staff_invited, review_received, message_received, payment_received, deposit_released']
  title varchar(255) [not null]
  body text
  related_entity_type varchar(30) [note: 'booking, lodging, staff_assignment, review, conversation, payment']
  related_entity_id uuid [note: 'ID de entite concernee']
  is_read boolean [default: false]
  read_at timestamp
  created_at timestamp [not null]
}
