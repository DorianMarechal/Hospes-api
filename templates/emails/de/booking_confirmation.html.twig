{% extends 'emails/base_email.html.twig' %}

{% block content %}
    <h2>Buchung bestätigt</h2>
    <p>Hallo {{ booking.customer.firstName }},</p>
    <p>Ihre Buchung wurde bestätigt.</p>

    <div class="detail">
        <p><strong>Referenz:</strong> {{ booking.reference }}</p>
        <p><strong>Unterkunft:</strong> {{ booking.lodging.name }}</p>
        <p><strong>Anreise:</strong> {{ booking.checkin|date('d.m.Y') }}</p>
        <p><strong>Abreise:</strong> {{ booking.checkout|date('d.m.Y') }}</p>
        <p><strong>Gäste:</strong> {{ booking.guestsCount }}</p>
        <p><strong>Gesamt:</strong> {{ (booking.totalPrice / 100)|number_format(2, ',', '.') }} {{ booking.currency }}</p>
    </div>

    <p>Wir wünschen Ihnen einen angenehmen Aufenthalt!</p>
{% endblock %}
