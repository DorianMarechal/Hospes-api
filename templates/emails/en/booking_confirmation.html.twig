{% extends 'emails/base_email.html.twig' %}

{% block content %}
    <h2>Booking confirmed</h2>
    <p>Hello {{ booking.customer.firstName }},</p>
    <p>Your booking has been confirmed.</p>

    <div class="detail">
        <p><strong>Reference:</strong> {{ booking.reference }}</p>
        <p><strong>Property:</strong> {{ booking.lodging.name }}</p>
        <p><strong>Check-in:</strong> {{ booking.checkin|date('d/m/Y') }}</p>
        <p><strong>Check-out:</strong> {{ booking.checkout|date('d/m/Y') }}</p>
        <p><strong>Guests:</strong> {{ booking.guestsCount }}</p>
        <p><strong>Total:</strong> {{ (booking.totalPrice / 100)|number_format(2, '.', ',') }} {{ booking.currency }}</p>
    </div>

    <p>We wish you a wonderful stay!</p>
{% endblock %}
